# Asana
ASANA_ACCESS_TOKEN=your_asana_personal_access_token

# Google OAuth (Gmail)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# NextAuth
NEXTAUTH_SECRET=generate_a_random_string_at_least_32_chars
NEXTAUTH_URL=http://localhost:3000

# اسم المستخدم للعرض
DISPLAY_NAME=شفيع الأنصاري

# اختياري — Anthropic (لاقتراحات الرد بالذكاء الاصطناعي)
ANTHROPIC_API_KEY=

# قاعدة البيانات
DATABASE_URL="file:./dev.db"
